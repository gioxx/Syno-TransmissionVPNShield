#!/bin/sh
# One-time activation script for Transmission VPN Shield.
# Run this as root from DSM Task Scheduler after the first install
# to complete privilege elevation and start the package.
#
# Task Scheduler → Create → Triggered Task → User-defined script
#   User: root
#   Command: /var/packages/transmission-vpn-shield/scripts/activate

PKG_NAME="transmission-vpn-shield"
PKG_DIR="/var/packages/${PKG_NAME}"

# Complete privilege elevation (merges privilege.elevated into privilege)
"${PKG_DIR}/scripts/postinst"

# Remove the 'installing' flag left by the failed first-run postinst
rm -f "${PKG_DIR}/installing"

# Start the package
synopkg start "${PKG_NAME}"
