#!/bin/sh

PKG_NAME="transmission-vpn-shield"
PKG_DIR="/var/packages/${PKG_NAME}"
TARGET_DIR="${PKG_DIR}/target"
UI_DIR="${TARGET_DIR}/ui"
CONF_SRC="${PKG_DIR}/conf/guard.conf"
CONF_DST_DIR="${TARGET_DIR}/conf"
CONF_DST="${CONF_DST_DIR}/guard.conf"
VAR_DIR="${PKG_DIR}/var"
LOG_FILE="${VAR_DIR}/install.log"
NEEDS_ACTIVATION_FLAG="${VAR_DIR}/needs-activation"

log() {
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "${LOG_FILE}" 2>/dev/null || echo "$1"
}

mkdir -p "${VAR_DIR}" "${CONF_DST_DIR}" || true
log "Post-installation starting for package: ${PKG_NAME}"

# guard.conf lives under ${PKG_DIR}/conf/ (the package conf folder
# protected by support_conf_folder=yes in package.json) so user edits
# survive upgrades. We expose it under target/conf/ via a symlink so
# every consumer (start-stop-status, guard-push, index.cgi) keeps
# finding it where they have always read it.
if [ -f "${CONF_SRC}" ]; then
  ln -sf "${CONF_SRC}" "${CONF_DST}" 2>/dev/null \
    && log "Linked ${CONF_DST} -> ${CONF_SRC}" \
    || log "WARN: could not link ${CONF_DST} -> ${CONF_SRC}"
else
  log "WARN: default guard.conf not found at ${CONF_SRC}"
fi

# Ensure UI executable
chmod +x "${UI_DIR}/index.cgi" 2>/dev/null || true

# Expose UI via webman
WEB_UI_LINK="/usr/syno/synoman/webman/3rdparty/${PKG_NAME}"
if ln -sf "${UI_DIR}" "${WEB_UI_LINK}" 2>/dev/null; then
  log "Created web interface symlink at ${WEB_UI_LINK}"
else
  log "Warning: failed to create web interface symlink at ${WEB_UI_LINK}"
fi

# Make sure index.conf and config have readable perms for DSM menu
for f in index.conf config; do
  if [ -f "${UI_DIR}/${f}" ]; then
    chmod 644 "${UI_DIR}/${f}" 2>/dev/null || true
  fi
done

# Privilege elevation requires root. DSM runs postinst as a restricted user on
# first install / upgrade, so we mark the package as needing activation and
# exit cleanly (status 0). The package shows as "Installed" in Package Center
# and the web UI guides the user through the one-time activation step.
# When the user runs /var/packages/transmission-vpn-shield/scripts/activate as
# root via Task Scheduler, postinst is called again as root, the elevation is
# applied and the needs-activation flag is removed.
if [ "$(id -u)" -ne 0 ]; then
  touch "${NEEDS_ACTIVATION_FLAG}"
  log "Not running as root — package marked as needing activation."
  log "Open the web UI and follow the on-screen instructions."
  exit 0
fi

# Running as root: apply privilege elevation
"$(dirname "$0")/_elevate"
rm -f "${NEEDS_ACTIVATION_FLAG}"
log "Post-installation completed successfully (elevated)"
exit 0
